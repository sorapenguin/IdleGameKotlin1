<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="12dp">

    <!-- ステータスカード -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/surface"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_total_attack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/gold"
                    android:text="総攻撃力: 0" />

                <TextView
                    android:id="@+id/tv_slot_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp"
                    android:text="スロット: 0 / 5" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_refresh_weapons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="更新"
                android:textSize="13sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 武器グリッド -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_weapons"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="12dp" />

    <!-- ゴミ箱（自動削除）設定 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/surface"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ゴミ箱"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_auto_delete_minus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="−"
                android:textSize="16sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <TextView
                android:id="@+id/tv_auto_delete_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="90dp"
                android:gravity="center"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:layout_marginHorizontal="8dp"
                android:text="無効" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_auto_delete_plus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="＋"
                android:textSize="16sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ジェム合成カード -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/surface"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ジェム合成"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/gem" />

                <TextView
                    android:id="@+id/tv_gems_weapon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp"
                    android:text="ジェム: 0  (10個 = 1分)" />

                <TextView
                    android:id="@+id/tv_pending_minutes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/gold"
                    android:layout_marginTop="4dp"
                    android:text="" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_gem_synth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="押す"
                android:textSize="14sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 合成ボタン -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_merge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="合成する"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <!-- スロット拡張ボタン -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_expand_slots"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="スロット拡張"
        android:textSize="14sp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

</LinearLayout>
