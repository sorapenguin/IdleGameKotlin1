# ホストにインストールされたPostgreSQLへ接続する
# （DockerコンテナからVPSホストへはhost.docker.internalで到達できる）
SPRING_DATASOURCE_URL=jdbc:postgresql://host.docker.internal:5432/idlegame_db
SPRING_DATASOURCE_USERNAME=idlegame_user
SPRING_DATASOURCE_PASSWORD=your_secure_password_here
JWT_SECRET=your_jwt_secret_at_least_32_chars_here
