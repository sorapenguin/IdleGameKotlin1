# =============================================
# IdleGame API - 環境変数テンプレート
# このファイルをコピーして .env として保存し、各値を記入してください。
#   cp .env.template .env
# =============================================

# ── サーバー設定 ──────────────────────────────
DOMAIN=your-domain.example.com
CERTBOT_EMAIL=your-email@example.com

# ── PostgreSQL ────────────────────────────────
# コンテナ名: shared-postgres（将来の別プロジェクトからも接続可能）
# 別プロジェクトから接続する場合は shared-db ネットワークに参加して
# ホスト名 shared-postgres を使う
POSTGRES_DB=idlegame_db
POSTGRES_USER=idlegame_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── JWT シークレット ──────────────────────────
# openssl rand -hex 32 で生成する。一度決めたら変えない。
JWT_SECRET=REPLACE_WITH_YOUR_LONG_RANDOM_SECRET_KEY_AT_LEAST_256_BITS
